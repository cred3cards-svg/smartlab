generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  OPERATIONS
  PATHOLOGIST
  PATIENT
}

enum BookingStatus {
  BOOKED
  ASSIGNED
  EN_ROUTE
  COLLECTED
  IN_LAB
  PROCESSING
  REVIEWED
  REPORT_READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  PARTIAL
}

enum ReportStatus {
  PENDING
  GENERATING
  VERIFIED
  PUBLISHED
}

enum SampleType {
  BLOOD
  URINE
  SWAB
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  ALL
}

enum BillingPeriod {
  MONTHLY
  QUARTERLY
  ANNUAL
}

enum ReferralStatus {
  PENDING
  VALIDATED
  REWARDED
  REJECTED
}

enum RewardType {
  WALLET_CREDIT
  FREE_PACKAGE
  CASH_REWARD
}

// ─── MODELS ───────────────────────────────────────────────────────

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(ADMIN)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  state           String
  heroTagline     String?
  centreCount     Int      @default(0)
  collectionTime  String?
  metaTitle       String?
  metaDescription String?
  areas           Area[]
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Area {
  id        String    @id @default(cuid())
  name      String
  pincode   String?
  cityId    String
  city      City      @relation(fields: [cityId], references: [id])
  addresses Address[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  tests       Test[]   @relation("TestCategories")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Test {
  id               String          @id @default(cuid())
  slug             String          @unique
  name             String
  shortDescription String
  price            Float
  originalPrice    Float
  discountPercent  Int             @default(0)
  reportTime       String
  homeCollection   Boolean         @default(true)
  fasting          Boolean         @default(false)
  fastingHours     Int?
  sampleType       SampleType      @default(BLOOD)
  parameterCount   Int             @default(0)
  organCategory    String?
  preparation      String[]
  whoShouldTake    String[]
  whyImportant     String?
  labDetails       String?
  popular          Boolean         @default(false)
  isNew            Boolean         @default(false)
  faqs             FAQ[]
  parameters       TestParameter[]
  categories       Category[]      @relation("TestCategories")
  packages         PackageItem[]
  bookings         TestBooking[]   @relation("BookingTests")
  active           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model TestParameter {
  id          String   @id @default(cuid())
  name        String
  unit        String?
  normalRange String?
  testId      String
  test        Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CheckupPackage {
  id                 String          @id @default(cuid())
  slug               String          @unique
  name               String
  tagline            String
  price              Float
  originalPrice      Float
  discountPercent    Int             @default(0)
  reportTime         String
  homeCollection     Boolean         @default(true)
  fasting            Boolean         @default(false)
  fastingHours       Int?
  parameterCount     Int             @default(0)
  testCount          Int             @default(0)
  gender             Gender          @default(ALL)
  ageGroup           String?
  purpose            String[]
  popular            Boolean         @default(false)
  recommended        Boolean         @default(false)
  membershipEligible Boolean         @default(true)
  preparation        String[]
  frequency          String?
  faqs               FAQ[]
  items              PackageItem[]
  bookings           TestBooking[]   @relation("BookingPackages")
  active             Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model PackageItem {
  id        String         @id @default(cuid())
  packageId String
  package   CheckupPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  testId    String?
  test      Test?          @relation(fields: [testId], references: [id])
  label     String? // For items that aren't specific tests (e.g., "Full Body Screening")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TestBooking {
  id             String         @id @default(cuid())
  bookingId      String         @unique // Human readable ID like SMB-12345
  status         BookingStatus  @default(BOOKED)
  paymentStatus  PaymentStatus  @default(UNPAID)
  totalAmount    Float
  discountAmount Float          @default(0)
  netAmount      Float
  patientId      String
  patient        BookingPatient @relation(fields: [patientId], references: [id])
  addressId      String
  address        Address        @relation(fields: [addressId], references: [id])
  slotId         String
  slot           TimeSlot       @relation(fields: [slotId], references: [id])
  tests          Test[]         @relation("BookingTests")
  packages       CheckupPackage[] @relation("BookingPackages")
  reports        TestReport[]
  referralCode   String?
  referral       ReferralEvent?
  couponCode     String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model BookingPatient {
  id        String        @id @default(cuid())
  name      String
  age       Int
  gender    Gender
  relation  String? // self, parent, spouse etc
  phone     String
  email     String?
  bookings  TestBooking[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Address {
  id         String        @id @default(cuid())
  street     String
  landmark   String?
  city       String
  state      String
  pincode    String
  areaId     String?
  area       Area?         @relation(fields: [areaId], references: [id])
  bookings   TestBooking[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model TimeSlot {
  id        String        @id @default(cuid())
  date      DateTime
  time      String
  available Boolean       @default(true)
  bookings  TestBooking[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountType    String // PERCENTAGE or FIXED
  value           Float
  maxDiscount     Float?
  minOrderValue   Float    @default(0)
  expiryDate      DateTime
  active          Boolean  @default(true)
  usageLimit      Int?
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MembershipPlan {
  id                   String                   @id @default(cuid())
  name                 String
  tagline              String?
  price                Float
  originalPrice        Float?
  billingPeriod        BillingPeriod            @default(ANNUAL)
  memberCount          Int                      @default(1)
  benefits             String[]
  discountOnTests      Int                      @default(0)
  freeHomeCollections  Int                      @default(0)
  prioritySlots        Boolean                  @default(false)
  reportSLAHours       Int                      @default(24)
  popular              Boolean                  @default(false)
  active               Boolean                  @default(true)
  subscriptions        MembershipSubscription[]
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
}

model MembershipSubscription {
  id        String         @id @default(cuid())
  planId    String
  plan      MembershipPlan @relation(fields: [planId], references: [id])
  userId    String // Linked to patient or order user
  startDate DateTime       @default(now())
  endDate   DateTime
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model TestReport {
  id           String       @id @default(cuid())
  bookingId    String
  booking      TestBooking  @relation(fields: [bookingId], references: [id])
  reportUrl    String
  status       ReportStatus @default(PENDING)
  pathologistId String?
  verifiedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model FAQ {
  id        String          @id @default(cuid())
  question  String
  answer    String
  category  String
  testId    String?
  test      Test?           @relation(fields: [testId], references: [id])
  packageId String?
  package   CheckupPackage? @relation(fields: [packageId], references: [id])
  active    Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  city      String
  rating    Int      @default(5)
  text      String
  testTaken String?
  verified  Boolean  @default(true)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DoctorBlock {
  id        String   @id @default(cuid())
  name      String
  specialty String
  hospital  String
  quote     String
  avatarUrl String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String
  city      String?
  source    String? // homepage, contact, package etc
  message   String?
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PatientAccount {
  id              String        @id @default(cuid())
  phone           String        @unique
  email           String?
  name            String?
  referralCode    ReferralCode?
  referralsMade   ReferralEvent[] @relation("Referrer")
  referralsGained ReferralEvent[] @relation("ReferredUser")
  rewards         RewardLedger[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ReferralCode {
  id        String         @id @default(cuid())
  code      String         @unique
  accountId String         @unique
  account   PatientAccount @relation(fields: [accountId], references: [id])
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
}

model ReferralEvent {
  id             String         @id @default(cuid())
  referrerId     String
  referrer       PatientAccount @relation("Referrer", fields: [referrerId], references: [id])
  referredUserId String
  referredUser   PatientAccount @relation("ReferredUser", fields: [referredUserId], references: [id])
  bookingId      String         @unique
  booking        TestBooking    @relation(fields: [bookingId], references: [id])
  status         ReferralStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model RewardLedger {
  id        String         @id @default(cuid())
  accountId String
  account   PatientAccount @relation(fields: [accountId], references: [id])
  type      RewardType
  amount    Float          @default(0)
  status    String         @default("PENDING") // PENDING, APPROVED, REJECTED
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}
